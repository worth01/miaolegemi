generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model cat_lineage {
  id                  String              @id
  serialId            String
  ownerId             String
  nickname            String
  daysLived           Int                 @default(0)
  fishSpent           Int                 @default(0)
  bestCombo           Int                 @default(0)
  intimacy            Int                 @default(0)
  releaseType         String              @default("主动送走")
  dateLeft            DateTime
  createdAt           DateTime            @default(now())
  users               users               @relation(fields: [ownerId], references: [id])
  cat_serial_registry cat_serial_registry @relation(fields: [serialId], references: [id])
}

model cat_serial_registry {
  id                                              String        @id
  speciesId                                       Int
  serialNumber                                    Int
  status                                          String        @default("available")
  currentOwnerId                                  String?
  firstOwnerId                                    String?
  availableAfter                                  DateTime?
  createdAt                                       DateTime      @default(now())
  cat_lineage                                     cat_lineage[]
  users_cat_serial_registry_currentOwnerIdTousers users?        @relation("cat_serial_registry_currentOwnerIdTousers", fields: [currentOwnerId], references: [id])
  users_cat_serial_registry_firstOwnerIdTousers   users?        @relation("cat_serial_registry_firstOwnerIdTousers", fields: [firstOwnerId], references: [id])
  cat_species                                     cat_species   @relation(fields: [speciesId], references: [id])
  player_cats                                     player_cats?

  @@unique([speciesId, serialNumber])
}

model cat_species {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique
  rarity              String
  activeSkill         Json
  passiveSkill        Json
  weight              Int
  description         String
  cat_serial_registry cat_serial_registry[]
}

model cat_personalities {
  id              Int    @id @default(autoincrement())
  personalityId   Int    @unique
  name            String @unique
  effectType      String
  effectDesc      String
  affectsFish     Boolean
  createdAt       DateTime @default(now())
}

model daily_boards {
  date DateTime @id @db.Date
  seed BigInt
}

model fish_ledger {
  id        String   @id
  userId    String
  amount    Int
  reason    String
  relatedId String?
  createdAt DateTime @default(now())
  users     users    @relation(fields: [userId], references: [id])
}

model game_sessions {
  id         String   @id
  playerId   String
  boardDate  DateTime @db.Date
  score      Int
  fishEarned Int
  activeCats Json
  comboCount Int      @default(0)
  duration   Int      @default(0)
  createdAt  DateTime @default(now())
  users      users    @relation(fields: [playerId], references: [id])
}

model player_cats {
  id                  String              @id
  ownerId             String
  serialId            String              @unique
  location            String              @default("bag")
  slotPosition        Int?
  bagExpiresAt        DateTime?
  acquiredAt          DateTime            @default(now())
  personality         Json
  intimacy            Int                 @default(0)
  lastFedAt           DateTime?
  gamesWitnessed      Int                 @default(0)
  bestCombo           Int                 @default(0)
  fishSpent           Int                 @default(0)
  daysAlive           Int                 @default(0)
  releasedAt          DateTime?
  coolingUntil        DateTime?
  updatedAt           DateTime
  users               users               @relation(fields: [ownerId], references: [id])
  cat_serial_registry cat_serial_registry @relation(fields: [serialId], references: [id])
}

model user_milestones {
  id           String   @id
  userId       String   @unique
  totalGames   Int      @default(0)
  totalFish    Int      @default(0)
  maxCombo     Int      @default(0)
  catsOwned    Int      @default(0)
  catsReleased Int      @default(0)
  updatedAt    DateTime
}

model users {
  id                                                            String                @id
  username                                                      String                @unique
  password                                                      String
  nickname                                                      String
  pityCount                                                     Int                   @default(0)
  createdAt                                                     DateTime              @default(now())
  updatedAt                                                     DateTime
  cat_lineage                                                   cat_lineage[]
  cat_serial_registry_cat_serial_registry_currentOwnerIdTousers cat_serial_registry[] @relation("cat_serial_registry_currentOwnerIdTousers")
  cat_serial_registry_cat_serial_registry_firstOwnerIdTousers   cat_serial_registry[] @relation("cat_serial_registry_firstOwnerIdTousers")
  fish_ledger                                                   fish_ledger[]
  game_sessions                                                 game_sessions[]
  player_cats                                                   player_cats[]
}
